{% doc %}
  @prompt
    Headline (H1):
    Better Sleep Starts Here
    
    Paragraph:
    “Naturally fall asleep faster, stay asleep longer, and wake up refreshed—with an all-natural formula designed to support deep, restorative rest.”
    
    Styling Instructions:
    
    White background
    
    Large bold black headline
    
    Medium gray paragraph
    
    Left-aligned text
    
    Clean, premium spacing (Apple-style)
    
    No borders
    
    PART 2 — Image Feature Card (Use the image I uploaded)
    
    Use my uploaded image as the hero visual.
    
    Below the image, add a dark text box:
    
    Title (H2):
    FALL ASLEEP FASTER
    
    Description:
    “Natural ingredients help calm your mind and body so you can drift off with ease—no more tossing or turning.”
    
    Styling Instructions:
    
    Image full width inside the card
    
    Text box background: solid black
    
    Text color: white
    
    Card has soft shadow + rounded corners
    
    Centered layout
    
    Mobile-optimized
    
    GLOBAL STYLE INSTRUCTIONS
    
    Keep everything minimalist and premium
    
    Layout similar to high-end wellness brands
    
    Extra spacing for a clean luxury look
    
    No extra colors—just black, white, and subtle shadows
    
    Make it responsive for all screen sizes
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-feature-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px {{ block.settings.section_padding_horizontal }}px;
    background-color: {{ block.settings.section_background }};
  }

  .ai-image-feature-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.card_max_width }}px;
    margin: 0 auto;
  }

  .ai-image-feature-card-{{ ai_gen_id }} {
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    background-color: #ffffff;
  }

  .ai-image-feature-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-image-feature-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-feature-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-feature-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-image-feature-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-feature-text-box-{{ ai_gen_id }} {
    background-color: {{ block.settings.text_box_background }};
    padding: {{ block.settings.text_box_padding }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    line-height: 1.3;
    letter-spacing: 0.02em;
    text-transform: {{ block.settings.title_transform }};
  }

  .ai-image-feature-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-image-feature-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px {{ block.settings.section_padding_horizontal | times: 0.6 }}px;
    }

    .ai-image-feature-text-box-{{ ai_gen_id }} {
      padding: {{ block.settings.text_box_padding | times: 0.7 }}px;
    }

    .ai-image-feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.75 }}px;
      margin-bottom: {{ block.settings.title_spacing | times: 0.7 }}px;
    }

    .ai-image-feature-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-image-feature-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-feature-container-{{ ai_gen_id }}">
    <div class="ai-image-feature-card-{{ ai_gen_id }}">
      <div class="ai-image-feature-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1600 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-image-feature-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-feature-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-image-feature-empty-state-{{ ai_gen_id }}">
              Add your product image
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-image-feature-text-box-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-image-feature-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        
        {% if block.settings.description != blank %}
          <div class="ai-image-feature-description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image feature card",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "FALL ASLEEP FASTER"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Natural ingredients help calm your mind and body so you can drift off with ease—no more tossing or turning.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "card_max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Card max width",
      "default": 700
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Corner radius",
      "default": 16
    },
    {
      "type": "range",
      "id": "shadow_horizontal",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Shadow horizontal",
      "default": 0
    },
    {
      "type": "range",
      "id": "shadow_vertical",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Shadow vertical",
      "default": 10
    },
    {
      "type": "range",
      "id": "shadow_blur",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Shadow blur",
      "default": 30
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "label": "Shadow opacity",
      "default": 0.1
    },
    {
      "type": "header",
      "content": "Text box style"
    },
    {
      "type": "color",
      "id": "text_box_background",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "text_box_padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding",
      "default": 50
    },
    {
      "type": "header",
      "content": "Title style"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 28
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 15
    },
    {
      "type": "header",
      "content": "Description style"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 16
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Vertical padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Image feature card"
    }
  ]
}
{% endschema %}
