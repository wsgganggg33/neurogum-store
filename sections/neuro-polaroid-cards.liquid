{{ 'neuro-polaroid-cards.css' | asset_url | stylesheet_tag }}

<div class="neuro-polaroid-section" style="background-color: {{ section.settings.bg_color }};">
  {%- if section.settings.wave_top -%}
    <div class="neuro-polaroid-section__wave neuro-polaroid-section__wave--top">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 60L48 52C96 44 192 28 288 22C384 16 480 20 576 28C672 36 768 48 864 50C960 52 1056 44 1152 36C1248 28 1344 20 1392 16L1440 12V0H1392C1344 0 1248 0 1152 0C1056 0 960 0 864 0C768 0 672 0 576 0C480 0 384 0 288 0C192 0 96 0 48 0H0V60Z" fill="{{ section.settings.wave_color }}"/>
      </svg>
    </div>
  {%- endif -%}

  {%- if section.settings.heading != blank -%}
    <h2 class="neuro-polaroid-section__heading" style="color: {{ section.settings.heading_color }};">
      {{ section.settings.heading }}
    </h2>
  {%- endif -%}

  <div class="neuro-polaroid-cards">
    {%- for block in section.blocks -%}
      <div class="neuro-polaroid-card" {{ block.shopify_attributes }} style="transform: rotate({{ block.settings.rotation }}deg);">
        <div class="neuro-polaroid-card__tape" style="background-color: {{ block.settings.tape_color }};"></div>
        <div class="neuro-polaroid-card__inner">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag:
              class: 'neuro-polaroid-card__image',
              loading: 'lazy',
              widths: '200, 300, 400, 600',
              sizes: '(max-width: 749px) 45vw, 25vw'
            }}
          {%- else -%}
            <div class="neuro-polaroid-card__placeholder">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
          {%- if block.settings.caption != blank -%}
            <p class="neuro-polaroid-card__caption" style="color: {{ section.settings.caption_color }};">{{ block.settings.caption }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.wave_bottom -%}
    <div class="neuro-polaroid-section__wave neuro-polaroid-section__wave--bottom">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 0L48 8C96 16 192 32 288 38C384 44 480 40 576 32C672 24 768 12 864 10C960 8 1056 16 1152 24C1248 32 1344 40 1392 44L1440 48V60H1392C1344 60 1248 60 1152 60C1056 60 960 60 864 60C768 60 672 60 576 60C480 60 384 60 288 60C192 60 96 60 48 60H0V0Z" fill="{{ section.settings.wave_color }}"/>
      </svg>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Polaroid Cards",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "When do you need more focus and energy?"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#00BCD4"
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption Color",
      "default": "#1a1a2e"
    },
    {
      "type": "checkbox",
      "id": "wave_top",
      "label": "Show Wave on Top",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "wave_bottom",
      "label": "Show Wave on Bottom",
      "default": true
    },
    {
      "type": "color",
      "id": "wave_color",
      "label": "Wave Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Polaroid Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Staying focused on long drives"
        },
        {
          "type": "range",
          "id": "rotation",
          "label": "Card Rotation",
          "min": -15,
          "max": 15,
          "step": 1,
          "default": -3,
          "unit": "°"
        },
        {
          "type": "color",
          "id": "tape_color",
          "label": "Tape Color",
          "default": "#a8e6cf"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Polaroid Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "caption": "Staying focused on long drives",
            "rotation": -5
          }
        },
        {
          "type": "card",
          "settings": {
            "caption": "To be productive at your best in office",
            "rotation": 3
          }
        },
        {
          "type": "card",
          "settings": {
            "caption": "Crushing it at the gym",
            "rotation": -2
          }
        },
        {
          "type": "card",
          "settings": {
            "caption": "Staying sharp while studying",
            "rotation": 4
          }
        }
      ]
    }
  ]
}
{% endschema %}
