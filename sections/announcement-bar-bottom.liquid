<style>
#shopify-section-sections--21428723974420__d2f19d4d-d8ca-4998-9d91-8b38a7bf9919{
  z-index: 1 !important;
}
.announcement-bar-second{
  padding: 10px;
  background: {{ section.settings.ann_bg }};
  display: flex;
  justify-content: center;
  gap: 15px
}
.announcement-bar-second .inner-ann{
  display: flex;
  align-items: center;
  gap: 7px;
}
.announcement-bar-second .inner-ann svg{
  width: 20px;
  fill: {{ section.settings.ann_txt }};
}
.announcement-bar-second .inner-ann p{
  margin: 0;
  color: {{ section.settings.ann_txt }};
}
@media only screen and (max-width: 480px){
  .announcement-bar-second{
    padding: 8px;
    gap: 10px
  }
  .announcement-bar-second .inner-ann p{
    font-size: 10px;
  }
}
</style>


