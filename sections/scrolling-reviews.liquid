            <p>{{ block.settings.b-review }}</p>
          </div>
          {%- endif -%}
         {%- endif -%}
        {%- endfor -%}
                         
      </div>
    </div>

  </div>
  
</div>


<style>
.scrolling-review-{{ section.id }}{
  padding: 50px 0;
}
.reviews_title {
  text-align: center;
  line-height: 1.3;
  font-weight: 600;
  margin-bottom: 50px;
  margin-top: 0px;
  padding: 0px 3rem;
  font-size: 42px;
}
.reviews_title span {
  background: linear-gradient(to right, {{ section.settings.title-color }} 0%,#fed8e0 50%, {{ section.settings.title-color }});
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.scrolling-review-wrapper {
  position: relative;
  display: flex;
  overflow: hidden;
  width: 100%;
}
.scrolling-rev.marquee {
  position: relative;
  animation: MarqueeLeft linear 45s infinite;
  min-width: 2350px !important;
}

@keyframes MarqueeLeft {
  0% {
    transform: translate(0);
  }
  100% {
    transform: translate(-100%);
  }
}

.scrolling-review-wrapper .image-holder {
  position: relative;
  display: flex;
  -webkit-box-align: center;
  align-items: center;
}
.scroll-bottom .image-holder {
  transform: translateX(-230px);
}
.review-item {
  min-width: 420px;
  min-height: 95px;
  background-color: #fff;
  display: flex;
  align-items: center;
  gap: 18px;
  padding: 10px 50px 10px 25px;
  margin: 30px 25px;
  box-shadow: 4px 4px 20px {{ section.settings.shadow-color }};
  border-radius: 100px;
}
.review-item img {
  border-radius: 50%;
  max-width: unset;
  width: 45px;
  height: 45px;
  object-fit: cover;
  position: relative;
}
.review-img {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}
.item_icon-review {
  font-size: 8px;
  color: #ffffff;
  position: absolute;
  bottom: 0;
  right: 0;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2px;
  background: linear-gradient(to right, {{ section.settings.title-color }} 0%,#fed8e0 50%, {{ section.settings.title-color }});
}
.review-item p{
  line-height: 1.5;
  font-size: 16px;
  margin: 0;
  color: #0b1128;
}

@media only screen and (max-width: 768px){
  .reviews_title {
    padding: 0px 2rem;
    font-size: 28px;
    margin-bottom: 25px;
  }
}
</style>


{% schema %}
  {
    "name": "Scrolling Reviews",
    "settings": [
      {
        "type": "inline_richtext",
        "id": "title",
        "label": "Title",
        "info": "Use the <span>HELLO</span> Tag for show the different Color"
      },
      {
        "type": "header",
        "content": "Colors"
      },
      {
        "type": "color",
        "id": "title-color",
        "label": "Title Different Color",
        "default": "#f86d83"
      },
      {
        "type": "color",
        "id": "shadow-color",
        "label": "Shadow Color",
        "default": "#ffe0e6"
      }
    ],
    "blocks": [
     {
      "type": "above_review",
      "name": "Above Review",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "client-image",
          "label": "Client Image"
        },
        {
          "type": "inline_richtext",
          "id": "review",
          "label": "Review"
        },
        {
          "type": "number",
          "id": "rating",
          "label": "Rating",
          "default": 5
        }
      ]
     },
     {
      "type": "below_review",
      "name": "Below Review",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "b-client-image",
          "label": "Client Image"
        },
        {
          "type": "inline_richtext",
          "id": "b-review",
          "label": "Review"
        },
        {
          "type": "number",
          "id": "b-rating",
          "label": "Rating",
          "default": 5
        }
      ]
     }
    ],
    "presets": [
      {
        "name": "Scrolling Reviews"
      }
    ]
  }
{% endschema %}
