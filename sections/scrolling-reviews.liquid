    </div>

    <div class="scrolling-rev marquee">
      <div class="image-holder">

        {%- for block in section.blocks -%}
         {%- if block.type == "below_review" -%}
          {%- if block.settings.b-review != blank -%}
          <div class="review-item">
            <div class="review-img">
              <img loading="lazy" src="{{ block.settings.b-client-image | img_url: 'original' }}">
