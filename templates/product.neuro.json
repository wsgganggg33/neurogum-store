      "type": "faqs",
      "blocks": {
        "faq_1": {
          "type": "faq",
          "settings": {
            "faq-ques": "What is Neuro Energy & Focus Mints?",
            "faq-content": "<p>Neuro Energy & Focus Mints are nootropic mints containing natural caffeine (40mg), L-theanine (60mg), Vitamin B6, and Vitamin B12. They provide a clean, balanced energy boost without the crash.</p>"
          }
        },
        "faq_2": {
          "type": "faq",
          "settings": {
            "faq-ques": "How many mints should I take?",
            "faq-content": "<p>We recommend starting with 1-2 mints at a time. Each mint contains 40mg of natural caffeine (roughly equivalent to half a cup of coffee). You can adjust based on your personal tolerance.</p>"
          }
        },
        "faq_3": {
          "type": "faq",
          "settings": {
            "faq-ques": "Are Neuro Mints sugar free?",
            "faq-content": "<p>Yes! Neuro Mints are 100% sugar free, aspartame free, gluten free, and vegan. They're designed to give you energy without any guilt.</p>"
          }
        },
        "faq_4": {
          "type": "faq",
          "settings": {
            "faq-ques": "How fast do they work?",
            "faq-content": "<p>Neuro Mints are absorbed through the buccal mucosa (the lining of your mouth), which means they work faster than pills or drinks. Most people feel the effects within 5-10 minutes.</p>"
          }
        },
        "faq_5": {
          "type": "faq",
          "settings": {
            "faq-ques": "What is the return policy?",
            "faq-content": "<p>We offer a 30-day money back guarantee. If you're not completely satisfied with your purchase, contact our customer service team for a full refund.</p>"
          }
        }
