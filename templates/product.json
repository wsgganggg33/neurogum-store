        "column_BUMTe4": {
          "type": "column",
          "settings": {
            "title": "<strong>Step 1: Prepare</strong>",
            "text": "<p>Ensure your scalp area and hair is clean and dry for best results. Our hair filler powder works best on dry hair and scalp.<br/><br/></p>",
