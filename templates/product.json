        "column_38bqiX": {
          "type": "column",
          "settings": {
            "title": "<strong>Step 2: Load the brush</strong>",
            "text": "<p>Remove the attached brush from the bottom, and gently dab it onto the powder. Dab as needed depending on the size of the area you're applying on.<br/></p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_7tbqQj": {
          "type": "column",
          "settings": {
            "title": "<strong>Step 3: Apply to targeted areas</strong>",
            "text": "<p>Gently stroke the brush onto areas of your scalp with thinning hair and bald patches, or areas of patchy beard or hairline, focusing on areas where you want fuller looking hair.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_xYHw6p": {
          "type": "column",
          "settings": {
            "title": "<strong>Step 4: See instant results</strong>",
            "text": "<p>Check out your instantly fuller, natural-looking hair. Let it dry naturally in 2-3 minutes or use your preferred hair spray to set your hair in place.<br/></p>",
            "link_label": "",
            "link": ""
          }
        }
      },
