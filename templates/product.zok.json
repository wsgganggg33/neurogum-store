text":"<p>We ship from within Bangladesh itself hence it gets to you in a couple of days.<\/p>","link_label":"","link":""}},"template--21428723876116__8bb65be9-da27-4363-93a6-7ef4f50d53a3-column-3":{"type":"column","settings":{"title":"Loved by thousands","text":"<p>Thousands of happy customers trust Zok for fast, natural relief from migraines and headaches<br\/><br\/><\/p>","link_label":"","link":""}}},"block_order":["template--21428723876116__8bb65be9-da27-4363-93a6-7ef4f50d53a3-column-1","template--21428723876116__8bb65be9-da27-4363-93a6-7ef4f50d53a3-column-3"],"settings":{"title":"<strong>Try Us Risk Free<\/strong>","heading_size":"h2","image_width":"third","image_ratio":"adapt","columns_desktop":3,"column_alignment":"center","background_style":"none","button_label":"","button_link":"","color_scheme":"accent-2","columns_mobile":"1","swipe_on_mobile":false,"padding_top":24,"padding_bottom":24}},"668dc45f-0738-4cce-beb7-38d94901a455":{"type":"image-with-text","blocks":{"template--21428723876116__668dc45f-0738-4cce-beb7-38d94901a455-heading-1":{"type":"heading","settings":{"heading":"100% Money Back Guarantee","heading_size":"h2"}},"template--21428723876116__668dc45f-0738-4cce-beb7-38d94901a455-text-1":{"type":"text","settings":{"text":"<p>We’re confident you’ll love your Zok relief tool — but if for any reason you’re not satisfied, we’ve got you covered.<\/p><p><strong>Try Zok risk-free.<\/strong> If it doesn’t work for you, simply return it within <strong>30 days<\/strong> for a <strong>full refund<\/strong>. No questions asked.<\/p><p><\/p>","text_style":"body"}}},"block_order":["template--21428723876116__668dc45f-0738-4cce-beb7-38d94901a455-heading-1","template--21428723876116__668dc45f-0738-4cce-beb7-38d94901a455-text-1"],"settings":{"image":"shopify:\/\/shop_images\/10_1024x_633d07b4-9b48-4fb8-ac13-f8c4c9a32fa5.jpg","height":"adapt","desktop_image_width":"medium","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","conte